/* ---------- Scheduler modal (calendar + time + repeat) ---------- */
const schedulerOverlay = document.getElementById('scheduler-modal-overlay');
const schedTitle = document.getElementById('sched-title');
const schedSub = document.getElementById('sched-sub');
const schedReasonWrap = document.getElementById('sched-reason-wrap');
const schedReason = document.getElementById('sched-reason');
const schedCalLabel = document.getElementById('sched-cal-label');
const calMonthLabel = document.getElementById('cal-month-label');
const calDaysEl = document.getElementById('cal-days');
const schedTimeInput = document.getElementById('sched-time');
const schedRepeatSelect = document.getElementById('sched-repeat');
const schedSummary = document.getElementById('sched-summary');
const schedConfirmBtn = document.getElementById('sched-confirm-btn');

const monthNames = ["January","February","March","April","May","June","July","August","September","October","November","December"];

let schedMode = 'schedule'; // 'schedule' | 'flag'
let calViewYear, calViewMonth;   // month currently displayed in the grid
let calSelectedDate = null;      // Date object (local, date-only)

function startOfDay(d){ return new Date(d.getFullYear(), d.getMonth(), d.getDate()); }
function isSameDate(a,b){
  return a && b && a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate();
}

function renderCalendar(){
  calMonthLabel.textContent = `${monthNames[calViewMonth]} ${calViewYear}`;
  calDaysEl.innerHTML = '';

  const today = startOfDay(new Date());
  const firstOfMonth = new Date(calViewYear, calViewMonth, 1);
  const startWeekday = firstOfMonth.getDay();
  const daysInMonth = new Date(calViewYear, calViewMonth+1, 0).getDate();
  const daysInPrevMonth = new Date(calViewYear, calViewMonth, 0).getDate();

  const cells = [];
  for(let i=0;i<startWeekday;i++){
    const dayNum = daysInPrevMonth - startWeekday + 1 + i;
    cells.push({ date: new Date(calViewYear, calViewMonth-1, dayNum), otherMonth: true });
  }
  for(let d=1; d<=daysInMonth; d++){
    cells.push({ date: new Date(calViewYear, calViewMonth, d), otherMonth: false });
  }
  let trail = 1;
  while(cells.length % 7 !== 0){
    cells.push({ date: new Date(calViewYear, calViewMonth+1, trail), otherMonth: true });
    trail++;
  }

  cells.forEach(cell=>{
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'cal-day';
    btn.textContent = cell.date.getDate();
    const isPast = cell.date < today && !isSameDate(cell.date, today);
    if(cell.otherMonth) btn.classList.add('other-month');
    if(isSameDate(cell.date, today)) btn.classList.add('today');
    if(isPast){ btn.classList.add('past'); btn.disabled = true; }
    if(isSameDate(cell.date, calSelectedDate)) btn.classList.add('selected');
    btn.addEventListener('click', ()=>{
      calSelectedDate = cell.date;
      if(cell.otherMonth){
        calViewYear = cell.date.getFullYear();
        calViewMonth = cell.date.getMonth();
      }
      renderCalendar();
      updateSchedSummary();
    });
    calDaysEl.appendChild(btn);
  });
}

document.getElementById('cal-prev').addEventListener('click', ()=>{
  calViewMonth -= 1;
  if(calViewMonth < 0){ calViewMonth = 11; calViewYear -= 1; }
  renderCalendar();
});
document.getElementById('cal-next').addEventListener('click', ()=>{
  calViewMonth += 1;
  if(calViewMonth > 11){ calViewMonth = 0; calViewYear += 1; }
  renderCalendar();
});

const repeatLabels = {
  none: 'once',
  daily: 'repeating daily',
  weekly: 'repeating weekly',
  biweekly: 'repeating every 2 weeks',
  monthly: 'repeating monthly'
};

function updateSchedSummary(){
  schedSummary.style.color = '';
  if(!calSelectedDate){
    schedSummary.textContent = 'Pick a date to see the schedule summary.';
    return;
  }
  const dateStr = `${monthNames[calSelectedDate.getMonth()].slice(0,3)} ${calSelectedDate.getDate()}, ${calSelectedDate.getFullYear()}`;
  const timeVal = schedTimeInput.value || '09:00';
  const repeatText = repeatLabels[schedRepeatSelect.value] || 'once';
  schedSummary.textContent = schedMode === 'schedule'
    ? `Inspection set for ${dateStr} at ${timeVal}, ${repeatText}.`
    : `Reminder set for ${dateStr} at ${timeVal}, ${repeatText}.`;
}
schedTimeInput.addEventListener('input', updateSchedSummary);
schedRepeatSelect.addEventListener('change', updateSchedSummary);

function openSchedulerModal(mode){
  schedMode = mode;
  schedSub.textContent = currentPanelData
    ? `Panel ${currentPanelData.id} · ${currentPanelData.array}`
    : 'No panel selected';

  if(mode === 'schedule'){
    schedTitle.textContent = 'Schedule Inspection';
    schedCalLabel.textContent = 'Inspection date';
    schedReasonWrap.style.display = 'none';
    schedConfirmBtn.textContent = 'Confirm Schedule';
  } else {
    schedTitle.textContent = 'Flag for Review';
    schedCalLabel.textContent = 'Reminder date';
    schedReasonWrap.style.display = 'block';
    schedReason.value = '';
    schedConfirmBtn.textContent = 'Confirm & Flag';
  }

  schedTimeInput.value = '09:00';
  schedRepeatSelect.value = 'none';
  calSelectedDate = null;
  const now = new Date();
  calViewYear = now.getFullYear();
  calViewMonth = now.getMonth();
  renderCalendar();
  updateSchedSummary();

  schedulerOverlay.classList.add('active');
}

function closeSchedulerModal(){
  schedulerOverlay.classList.remove('active');
}

document.getElementById('scheduler-close-btn').addEventListener('click', closeSchedulerModal);
document.getElementById('sched-cancel-btn').addEventListener('click', closeSchedulerModal);
schedulerOverlay.addEventListener('click', (e)=>{
  if(e.target === schedulerOverlay) closeSchedulerModal();
});

document.getElementById('pm-schedule-btn').addEventListener('click', ()=>{
  openSchedulerModal('schedule');
});
document.getElementById('pm-flag-btn').addEventListener('click', ()=>{
  openSchedulerModal('flag');
});

schedConfirmBtn.addEventListener('click', ()=>{
  if(!calSelectedDate){
    schedSummary.style.color = 'var(--heat)';
    schedSummary.textContent = 'Choose a date on the calendar first.';
    return;
  }
  const dateStr = `${monthNames[calSelectedDate.getMonth()].slice(0,3)} ${calSelectedDate.getDate()}, ${calSelectedDate.getFullYear()}`;
  const timeVal = schedTimeInput.value || '09:00';
  const repeatText = repeatLabels[schedRepeatSelect.value] || 'once';
  const panelId = currentPanelData ? currentPanelData.id : '—';

  if(schedMode === 'schedule'){
    showToast('Inspection scheduled', `Panel ${panelId} · ${dateStr} at ${timeVal}, ${repeatText}.`);
  } else {
    const reasonText = schedReason.value.trim();
    showToast(
      'Panel flagged for review',
      `Panel ${panelId} flagged.${reasonText ? ' Note: ' + reasonText + '.' : ''} Reminder ${dateStr} at ${timeVal}, ${repeatText}.`
    );
  }

  closeSchedulerModal();
  closePanelModal();
});

