/* ---------- GPS hover coordinate readout ---------- */
const GPS_BASE = { lat: 34.3917, lon: -119.0724 }; // coordinate of the fixed marker
const GPS_MARKER_FRAC = { x: 0.485, y: 0.27 };     // matches .gps-marker's left/top %
const GPS_VIEWBOX = { w: 400, h: 240 };            // matches the <svg viewBox>
const GPS_METERS_PER_UNIT = 1.15;                  // ~460m across the site, isotropic scale

const gpsArrayRects = [
  { name: 'Array A', x: 40,  y: 40,  w: 90, h: 50 },
  { name: 'Array B', x: 150, y: 40,  w: 90, h: 50 },
  { name: 'Array C', x: 40,  y: 120, w: 90, h: 50 },
  { name: 'Array D', x: 150, y: 120, w: 90, h: 50 }
];

function calcGpsAtFraction(xFrac, yFrac){
  const svgX = xFrac * GPS_VIEWBOX.w;
  const svgY = yFrac * GPS_VIEWBOX.h;
  const markerSvgX = GPS_MARKER_FRAC.x * GPS_VIEWBOX.w;
  const markerSvgY = GPS_MARKER_FRAC.y * GPS_VIEWBOX.h;

  const dxMeters = (svgX - markerSvgX) * GPS_METERS_PER_UNIT;
  const dyMeters = (svgY - markerSvgY) * GPS_METERS_PER_UNIT;

  const dLat = -(dyMeters / 111320);
  const dLon = dxMeters / (111320 * Math.cos(GPS_BASE.lat * Math.PI / 180));

  return { lat: GPS_BASE.lat + dLat, lon: GPS_BASE.lon + dLon };
}

function formatGpsCoord(lat, lon){
  const latDir = lat >= 0 ? 'N' : 'S';
  const lonDir = lon >= 0 ? 'E' : 'W';
  return `${Math.abs(lat).toFixed(5)}° ${latDir}, ${Math.abs(lon).toFixed(5)}° ${lonDir}`;
}

const gpsMapEl = document.getElementById('gps-map');
const gpsHoverDot = document.getElementById('gps-hover-dot');
const gpsTooltip = document.getElementById('gps-tooltip');
const gpsRectEls = Array.from(gpsMapEl.querySelectorAll('.array-block'));

gpsMapEl.addEventListener('mousemove', (e)=>{
  const bounds = gpsMapEl.getBoundingClientRect();
  const xFrac = (e.clientX - bounds.left) / bounds.width;
  const yFrac = (e.clientY - bounds.top) / bounds.height;
  if(xFrac < 0 || xFrac > 1 || yFrac < 0 || yFrac > 1) return;

  const svgX = xFrac * GPS_VIEWBOX.w;
  const svgY = yFrac * GPS_VIEWBOX.h;
  const hit = gpsArrayRects.find(r => svgX >= r.x && svgX <= r.x + r.w && svgY >= r.y && svgY <= r.y + r.h);

  gpsRectEls.forEach(el=>{
    el.classList.toggle('hovered', !!hit && el.dataset.name === hit.name);
  });

  const { lat, lon } = calcGpsAtFraction(xFrac, yFrac);
  const coordStr = formatGpsCoord(lat, lon);

  gpsTooltip.innerHTML = hit
    ? `<div class="gps-tooltip-title">${hit.name}</div><div class="gps-tooltip-coord">${coordStr}</div>`
    : `<div class="gps-tooltip-coord">${coordStr}</div>`;

  const hoverX = e.clientX - bounds.left;
  const hoverY = e.clientY - bounds.top;
  gpsHoverDot.style.left = hoverX + 'px';
  gpsHoverDot.style.top = hoverY + 'px';
  gpsHoverDot.classList.add('active');

  let tipLeft = hoverX + 14;
  let tipTop = hoverY + 14;
  const tipW = gpsTooltip.offsetWidth;
  const tipH = gpsTooltip.offsetHeight;
  if(tipLeft + tipW > bounds.width) tipLeft = hoverX - tipW - 14;
  if(tipTop + tipH > bounds.height) tipTop = hoverY - tipH - 14;
  gpsTooltip.style.left = tipLeft + 'px';
  gpsTooltip.style.top = tipTop + 'px';
  gpsTooltip.classList.add('active');
});

gpsMapEl.addEventListener('mouseleave', ()=>{
  gpsHoverDot.classList.remove('active');
  gpsTooltip.classList.remove('active');
  gpsRectEls.forEach(el => el.classList.remove('hovered'));
});

