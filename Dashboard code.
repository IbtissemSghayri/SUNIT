<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SolarSight  — Farm Monitoring</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #0A0F17;
    --panel: #101826;
    --panel-2: #0D1420;
    --line: #1E2A3D;
    --text: #E7ECF3;
    --muted: #7C8AA0;
    --amber: #F2A93B;   /* solar / energy */
    --amber-dim: #6B5323;
    --heat: #E4572E;    /* thermal / fault */
    --heat-dim: #4A231A;
    --ok: #3ECF8E;
    --ok-dim: #1E4A38;
    --warn: #F2C94C;
    --radius: 10px;
    --mono: 'JetBrains Mono', monospace;
    --display: 'Space Grotesk', sans-serif;
    --body: 'Inter', sans-serif;
  }

  *{ box-sizing: border-box; }

  html, body{
    margin:0; padding:0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--body);
    height: 100%;
  }

  body{
    background-image:
      radial-gradient(circle at 15% 0%, rgba(242,169,59,0.06), transparent 40%),
      radial-gradient(circle at 85% 10%, rgba(228,87,46,0.05), transparent 35%);
  }

  .app{
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px 24px 48px;
  }

  /* ---------- Top bar ---------- */
  .topbar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding: 14px 20px;
    background: linear-gradient(180deg, #121C2C, #0F1826);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    margin-bottom: 18px;
  }
  .brand{
    display:flex;
    align-items:center;
    gap:12px;
  }
  .brand-mark{
    width: 34px; height: 34px;
    border-radius: 8px;
    background: conic-gradient(from 220deg, var(--amber), var(--heat), var(--amber));
    display:flex; align-items:center; justify-content:center;
    font-family: var(--display);
    font-weight:700;
    font-size: 15px;
    color: #0A0F17;
  }
  .brand-text h1{
    font-family: var(--display);
    font-size: 18px;
    font-weight: 600;
    margin:0;
    letter-spacing: 0.2px;
  }
  .brand-text span{
    font-size: 11.5px;
    color: var(--muted);
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }
  .status-pill{
    display:flex; align-items:center; gap:8px;
    padding: 7px 14px;
    background: rgba(62,207,142,0.08);
    border: 1px solid var(--ok-dim);
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ok);
  }
  .dot{
    width:8px; height:8px; border-radius:50%;
    background: var(--ok);
    box-shadow: 0 0 0 0 rgba(62,207,142,0.6);
    animation: pulse 2s infinite;
  }
  @keyframes pulse{
    0%{ box-shadow:0 0 0 0 rgba(62,207,142,0.55); }
    70%{ box-shadow:0 0 0 8px rgba(62,207,142,0); }
    100%{ box-shadow:0 0 0 0 rgba(62,207,142,0); }
  }

  /* ---------- Section labels ---------- */
  .section-label{
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 10px 2px;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .section-label::before{
    content:'';
    width: 3px; height: 12px;
    background: var(--amber);
    border-radius: 2px;
    display:inline-block;
  }

  /* ---------- Stat cards ---------- */
  .stats{
    display:grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 20px;
  }
  .card{
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px 18px;
    position: relative;
    overflow:hidden;
  }
  .card::after{
    content:'';
    position:absolute; right:-20px; top:-20px;
    width:80px; height:80px;
    border-radius:50%;
    background: var(--accent, rgba(242,169,59,0.08));
    filter: blur(2px);
  }
  .card .label{
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .card .value{
    font-family: var(--mono);
    font-size: 28px;
    font-weight: 700;
  }
  .card .sub{
    font-size: 11.5px;
    color: var(--muted);
    margin-top: 6px;
  }
  .card .sub.up{ color: var(--ok); }
  .card .sub.down{ color: var(--heat); }
  .card.c-panels{ --accent: rgba(242,169,59,0.10); }
  .card.c-scanned{ --accent: rgba(62,207,142,0.10); }
  .card.c-faults .value{ color: var(--heat); }
  .card.c-faults{ --accent: rgba(228,87,46,0.12); }
  .card.c-temp .value{ color: var(--warn); }

  /* ---------- Grid layout ---------- */
  .row{
    display:grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 14px;
    margin-bottom: 20px;
  }
  .panel{
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px 18px 18px;
    display:flex;
    flex-direction:column;
  }
  .panel-head{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom: 12px;
  }
  .panel-head h2{
    font-family: var(--display);
    font-size: 14.5px;
    font-weight:600;
    margin:0;
  }
  .panel-head .hint{
    font-size: 11px;
    color: var(--muted);
    font-family: var(--mono);
  }

  /* ---------- Farm map ---------- */
  .map-wrap{
    flex:1;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    display:flex;
    align-items:center;
    justify-content:center;
    padding: 16px;
    min-height: 240px;
  }
  .legend{
    display:flex; gap:16px; margin-top:12px;
    font-size: 11.5px; color: var(--muted);
  }
  .legend span{ display:flex; align-items:center; gap:6px; }
  .legend i{ width:8px; height:8px; border-radius:50%; display:inline-block; }

  #farm-map rect{
    cursor: pointer;
    transition: opacity 0.12s ease, stroke 0.12s ease;
  }
  #farm-map rect:hover{
    opacity: 1 !important;
    stroke: #fff;
    stroke-width: 1.5px;
  }
  #farm-map rect.selected{
    stroke: var(--amber);
    stroke-width: 2px;
    opacity: 1 !important;
  }

  /* ---------- GPS Location panel ---------- */
  .gps-map{
    position: relative;
    flex:1;
    min-height: 240px;
    border-radius: 8px;
    overflow:hidden;
    border: 1px solid var(--line);
    background: var(--panel-2);
    cursor: crosshair;
  }
  .gps-grid{ position:absolute; inset:0; width:100%; height:100%; }
  .gps-grid rect.array-block{ transition: fill 0.12s ease, stroke 0.12s ease; }
  .gps-grid rect.array-block.hovered{
    fill: rgba(242,169,59,0.34);
    stroke: var(--amber);
    stroke-width: 1.5px;
  }

  .gps-marker{
    position:absolute;
    left: 48.5%;
    top: 27%;
    width: 12px; height:12px;
    margin: -6px 0 0 -6px;
    border-radius:50%;
    background: var(--amber);
    box-shadow: 0 0 14px 2px rgba(242,169,59,0.65);
    z-index:2;
  }
  .gps-ring{
    position:absolute;
    left: 48.5%;
    top: 27%;
    width: 12px; height:12px;
    margin: -6px 0 0 -6px;
    border-radius:50%;
    border: 1.5px solid var(--amber);
    opacity:0;
    animation: gps-pulse 2.6s ease-out infinite;
  }
  .gps-ring.delay{ animation-delay: 1.3s; }
  @keyframes gps-pulse{
    0%{ transform: scale(1); opacity: 0.65; }
    100%{ transform: scale(9); opacity: 0; }
  }

  /* Hover crosshair + coordinate readout tooltip */
  .gps-hover-dot{
    position:absolute;
    width:8px; height:8px;
    margin:-4px 0 0 -4px;
    border-radius:50%;
    background: rgba(231,236,243,0.95);
    border: 1.5px solid var(--bg);
    box-shadow: 0 0 0 1px rgba(231,236,243,0.45);
    pointer-events:none;
    z-index:3;
    display:none;
  }
  .gps-hover-dot.active{ display:block; }
  .gps-hover-dot::before, .gps-hover-dot::after{
    content:'';
    position:absolute;
    background: rgba(231,236,243,0.55);
  }
  .gps-hover-dot::before{ left:50%; top:-9px; width:1px; height:6px; transform:translateX(-50%); }
  .gps-hover-dot::after{ left:50%; bottom:-9px; width:1px; height:6px; transform:translateX(-50%); }

  .gps-tooltip{
    position:absolute;
    pointer-events:none;
    z-index:4;
    background: rgba(10,15,23,0.94);
    border: 1px solid var(--amber-dim);
    border-radius: 6px;
    padding: 6px 10px;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.1s ease, transform 0.1s ease;
  }
  .gps-tooltip.active{ opacity:1; transform: translateY(0); }
  .gps-tooltip-title{
    font-family: var(--display);
    font-size: 11.5px;
    font-weight: 600;
    color: var(--amber);
    margin-bottom: 2px;
  }
  .gps-tooltip-coord{
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
  }

  .gps-meta{
    display:flex; justify-content:space-between;
    align-items:center;
    margin-top: 10px;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--muted);
  }
  .gps-meta .gps-status{ color: var(--ok); }

  /* ---------- Tables ---------- */
  table{
    width:100%;
    border-collapse: collapse;
    font-size: 12.5px;
  }
  thead th{
    text-align:left;
    font-size: 10.5px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--muted);
    padding: 8px 10px;
    border-bottom: 1px solid var(--line);
    font-weight: 500;
  }
  tbody td{
    padding: 10px 10px;
    border-bottom: 1px solid var(--line);
    color: var(--text);
  }
  tbody tr:last-child td{ border-bottom:none; }
  tbody tr:hover{ background: rgba(255,255,255,0.02); }
  .mono{ font-family: var(--mono); }
  .badge{
    display:inline-block;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 10.5px;
    font-family: var(--mono);
    letter-spacing: 0.3px;
  }
  .badge.high{ background: rgba(228,87,46,0.15); color: var(--heat); border:1px solid var(--heat-dim); }
  .badge.med{ background: rgba(242,201,76,0.12); color: var(--warn); border:1px solid #5a4a1c; }
  .badge.low{ background: rgba(62,207,142,0.12); color: var(--ok); border:1px solid var(--ok-dim); }

  /* ---------- Alerts ---------- */
  .alerts{ list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px; }
  .alerts li{
    display:flex; gap:10px;
    padding: 10px 12px;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    align-items:flex-start;
  }
  .alerts .a-dot{
    width:8px; height:8px; border-radius:50%;
    margin-top:5px; flex-shrink:0;
  }
  .alerts .a-body{ flex:1; }
  .alerts .a-title{ font-size: 12.5px; font-weight:500; }
  .alerts .a-time{ font-size: 11px; color: var(--muted); font-family: var(--mono); margin-top:2px; }

  /* ---------- History ---------- */
  .history-actions{ display:flex; gap:8px; }
  .btn{
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--text);
    background: var(--panel-2);
    border: 1px solid var(--line);
    padding: 6px 12px;
    border-radius: 6px;
    cursor:pointer;
  }
  .btn:hover{ border-color: var(--amber); color: var(--amber); }
  .link-btn{
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--amber);
    background: transparent;
    border: 1px solid var(--amber-dim);
    padding: 4px 10px;
    border-radius: 6px;
    cursor:pointer;
  }
  .link-btn:hover{ background: rgba(242,169,59,0.08); }

  footer{
    text-align:center;
    color: var(--muted);
    font-size: 11px;
    margin-top: 10px;
    font-family: var(--mono);
  }

  /* ---------- Panel detail modal ---------- */
  .modal-overlay{
    position: fixed;
    inset: 0;
    background: rgba(5,8,13,0.72);
    backdrop-filter: blur(3px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 20px;
  }
  .modal-overlay.active{ display:flex; }
  .panel-modal{
    width: 560px;
    max-width: 100%;
    max-height: 88vh;
    overflow-y: auto;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px 22px 22px;
    position: relative;
    box-shadow: 0 24px 70px rgba(0,0,0,0.55);
  }
  .panel-modal .close-btn{
    position:absolute; top:14px; right:14px;
    width: 28px; height: 28px;
    display:flex; align-items:center; justify-content:center;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--muted);
    font-size: 15px;
    cursor:pointer;
  }
  .panel-modal .close-btn:hover{ color: var(--text); border-color: var(--amber); }
  .panel-modal .modal-head{ margin-bottom: 4px; padding-right: 30px; }
  .panel-modal h3{
    font-family: var(--display);
    font-size: 17px;
    margin: 0 0 4px;
  }
  .panel-modal .pm-sub{
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .cam-row{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 4px;
  }
  .cam-col{
    display:flex;
    flex-direction:column;
  }
  .cam-label{
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.7px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .cam-frame{
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: #05070b;
  }
  .cam-caption{
    display:flex; justify-content:space-between;
    gap: 6px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    margin: 6px 2px 0;
  }
  .cam-caption span{ overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  @media (max-width: 480px){
    .cam-row{ grid-template-columns: 1fr; }
  }
  .detail-grid{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 12px;
    margin-bottom: 14px;
  }
  .detail-item{
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 9px 11px;
  }
  .detail-item.span-2{ grid-column: 1 / -1; }
  .detail-item .dl{
    font-size: 10px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .detail-item .dv{
    font-family: var(--mono);
    font-size: 13.5px;
  }
  .detail-item .dv.heat{ color: var(--heat); }
  .detail-item .dv.warn{ color: var(--warn); }
  .detail-item .dv.ok{ color: var(--ok); }
  .modal-actions{ display:flex; gap:8px; margin-top: 18px; }
  .btn.primary{
    background: var(--amber);
    border-color: var(--amber);
    color: #0A0F17;
    font-weight: 600;
  }
  .btn.primary:hover{ background:#ffbf5c; color:#0A0F17; border-color:#ffbf5c; }

  /* ---------- Scheduler modal (Schedule Inspection / Flag for Review) ---------- */
  .scheduler-modal{
    width: 380px;
    max-width: 100%;
    max-height: 88vh;
    overflow-y: auto;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px 22px 22px;
    position: relative;
    box-shadow: 0 24px 70px rgba(0,0,0,0.55);
  }
  .scheduler-modal .close-btn{
    position:absolute; top:14px; right:14px;
    width: 28px; height: 28px;
    display:flex; align-items:center; justify-content:center;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--muted);
    font-size: 15px;
    cursor:pointer;
  }
  .scheduler-modal .close-btn:hover{ color: var(--text); border-color: var(--amber); }
  .scheduler-modal .modal-head{ margin-bottom: 6px; padding-right: 30px; }
  .scheduler-modal h3{
    font-family: var(--display);
    font-size: 17px;
    margin: 0 0 4px;
  }
  .scheduler-modal .pm-sub{
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
  }

  .field-label{
    font-size: 10.5px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--muted);
    margin: 16px 0 8px;
    display:block;
  }

  .sched-textarea{
    width: 100%;
    min-height: 54px;
    resize: vertical;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
    font-family: var(--body);
    font-size: 12.5px;
    padding: 9px 11px;
  }
  .sched-textarea:focus{ outline:none; border-color: var(--amber); }

  /* Calendar */
  .calendar{
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px;
  }
  .cal-head{
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom: 10px;
  }
  .cal-head .cal-title{
    font-family: var(--mono);
    font-size: 12.5px;
    font-weight: 500;
  }
  .cal-nav-btn{
    width: 24px; height: 24px;
    display:flex; align-items:center; justify-content:center;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--muted);
    cursor:pointer;
    font-size: 12px;
  }
  .cal-nav-btn:hover{ color: var(--amber); border-color: var(--amber-dim); }
  .cal-weekdays{
    display:grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 4px;
  }
  .cal-weekdays span{
    text-align:center;
    font-size: 10px;
    color: var(--muted);
    font-family: var(--mono);
  }
  .cal-days{
    display:grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
  }
  .cal-day{
    aspect-ratio: 1;
    display:flex; align-items:center; justify-content:center;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--text);
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    cursor: pointer;
  }
  .cal-day:hover{ border-color: var(--amber-dim); }
  .cal-day.other-month{ color: #3a4658; }
  .cal-day.today{ border-color: var(--line); color: var(--amber); }
  .cal-day.past{ color: #3a4658; cursor:not-allowed; }
  .cal-day.selected{
    background: var(--amber);
    color: #0A0F17;
    font-weight: 700;
    border-color: var(--amber);
  }

  .field-row{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .sched-input, .sched-select{
    width: 100%;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 12.5px;
    padding: 9px 10px;
    color-scheme: dark;
  }
  .sched-input:focus, .sched-select:focus{ outline:none; border-color: var(--amber); }

  .sched-summary{
    margin-top: 16px;
    padding: 10px 12px;
    background: rgba(242,169,59,0.06);
    border: 1px solid var(--amber-dim);
    border-radius: 8px;
    font-size: 11.5px;
    color: var(--amber);
    font-family: var(--mono);
    line-height: 1.5;
  }

  /* Toast notifications */
  .toast-stack{
    position: fixed;
    bottom: 22px;
    right: 22px;
    display:flex;
    flex-direction: column;
    gap: 10px;
    z-index: 200;
  }
  .toast{
    background: var(--panel);
    border: 1px solid var(--ok-dim);
    border-left: 3px solid var(--ok);
    border-radius: 8px;
    padding: 12px 16px;
    max-width: 300px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.4);
    animation: toast-in 0.25s ease;
  }
  .toast .toast-title{ font-weight: 600; margin-bottom: 3px; font-family: var(--display); font-size: 13px; }
  .toast .toast-body{ color: var(--muted); font-family: var(--mono); font-size: 11px; line-height:1.5; }
  @keyframes toast-in{
    from{ transform: translateX(20px); opacity:0; }
    to{ transform: translateX(0); opacity:1; }
  }
  .toast.fade-out{ animation: toast-out 0.25s ease forwards; }
  @keyframes toast-out{
    from{ opacity:1; }
