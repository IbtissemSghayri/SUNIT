<script>
/* ---------- Login gate ---------- */
const DEMO_USER = 'demo';
const DEMO_PASS = 'solarsight';

const loginScreen = document.getElementById('login-screen');
const appRoot = document.getElementById('app-root');
const loginForm = document.getElementById('login-form');
const loginUsernameInput = document.getElementById('login-username');
const loginPasswordInput = document.getElementById('login-password');
const loginErrorEl = document.getElementById('login-error');
const loginCardEl = document.querySelector('.login-card');
const userNameEl = document.getElementById('user-name');
const userAvatarEl = document.getElementById('user-avatar');
const logoutBtn = document.getElementById('logout-btn');

appRoot.style.display = 'none';
loginUsernameInput.focus();

loginForm.addEventListener('submit', (e)=>{
  e.preventDefault();
  const u = loginUsernameInput.value.trim();
  const p = loginPasswordInput.value;

  if(u.toLowerCase() === DEMO_USER && p === DEMO_PASS){
    loginErrorEl.classList.remove('active');
    loginUsernameInput.classList.remove('error');
    loginPasswordInput.classList.remove('error');
    loginScreen.classList.add('hidden');
    appRoot.style.display = 'block';
    userNameEl.textContent = u;
    userAvatarEl.textContent = u.charAt(0).toUpperCase();
    loginPasswordInput.value = '';
  } else {
    loginErrorEl.classList.add('active');
    loginUsernameInput.classList.add('error');
    loginPasswordInput.classList.add('error');
    loginCardEl.classList.remove('shake');
    void loginCardEl.offsetWidth; // restart the shake animation
    loginCardEl.classList.add('shake');
    loginPasswordInput.value = '';
    loginPasswordInput.focus();
  }
});

logoutBtn.addEventListener('click', ()=>{
  appRoot.style.display = 'none';
  loginScreen.classList.remove('hidden');
  loginUsernameInput.value = '';
  loginPasswordInput.value = '';
  loginErrorEl.classList.remove('active');
  loginUsernameInput.classList.remove('error');
  loginPasswordInput.classList.remove('error');
  loginUsernameInput.focus();
});

/* ---------- Sample data ---------- */
const faultTypes = ["Hotspot", "Micro-crack", "Delamination", "Diode Failure", "Soiling", "Shading"];
const arrays = ["Array A", "Array B", "Array C", "Array D"];
const severities = ["high", "med", "low"];

function randomFrom(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
function pad(n){ return n.toString().padStart(2,'0'); }

function timeAgo(mins){
  if(mins < 60) return mins + " min ago";
  return Math.floor(mins/60) + "h " + (mins%60) + "m ago";
}

/* ---------- Farm map (SVG grid of panels) ---------- */
const svg = document.getElementById('farm-map');
const cols = 26, rows = 8, cellW = 18, cellH = 22, gap = 2;
const svgNS = "http://www.w3.org/2000/svg";
const statusColors = { normal: 'var(--ok)', warning: 'var(--warn)', fault: 'var(--heat)' };

// crack location options, described relative to the panel face
const crackSpots = [
  "top-left corner", "top edge", "top-right corner",
  "left edge", "center", "right edge",
  "bottom-left corner", "bottom edge", "bottom-right corner",
  "diagonal, corner to corner"
];

const panelDataStore = {}; // key: "r-c" -> panel data object
let selectedRect = null;
let currentPanelData = null; // panel currently shown in the detail modal

for(let r=0;r<rows;r++){
  for(let c=0;c<cols;c++){
    const rand = Math.random();
    let status = 'normal';
    if(rand > 0.97) status = 'fault';
    else if(rand > 0.9) status = 'warning';

    // Determine temperature based on status
    let temp;
    if(status === 'fault') temp = (60 + Math.random()*18).toFixed(1);
    else if(status === 'warning') temp = (46 + Math.random()*9).toFixed(1);
    else temp = (35 + Math.random()*10).toFixed(1);

    // Determine crack: faults often cracked, warnings sometimes, normals rarely
    let cracked = false;
    if(status === 'fault') cracked = Math.random() > 0.35;
    else if(status === 'warning') cracked = Math.random() > 0.8;
    else cracked = Math.random() > 0.985;
    const crackLocation = cracked ? randomFrom(crackSpots) : null;

    // Assign array by column quadrant (4 arrays across the grid)
    const arrayIndex = Math.floor(c / (cols/4));
    const arrayName = arrays[Math.min(arrayIndex, arrays.length-1)];
    const panelId = `${arrayName[arrayName.length-1]}-${100 + r*cols + c}`;

    const data = {
      id: panelId,
      row: r, col: c,
      array: arrayName,
      status: status,
      temp: temp,
      cracked: cracked,
      crackLocation: crackLocation
    };
    panelDataStore[`${r}-${c}`] = data;

    const rect = document.createElementNS(svgNS, 'rect');
    rect.setAttribute('x', c*(cellW+gap)+6);
    rect.setAttribute('y', r*(cellH+gap)+6);
    rect.setAttribute('width', cellW);
    rect.setAttribute('height', cellH);
    rect.setAttribute('rx', 2);
    rect.setAttribute('fill', statusColors[status]);
    rect.setAttribute('opacity', status==='normal' ? 0.55 : 0.95);
    rect.dataset.key = `${r}-${c}`;
    rect.addEventListener('click', () => openPanelModal(data, rect));
    svg.appendChild(rect);
  }
}

/* ---------- Panel detail modal ---------- */
const modalOverlay = document.getElementById('panel-modal-overlay');
// Cache the STABLE containers (.cam-frame) rather than an <svg> element itself.
// We update these with innerHTML on every click, which always targets the live
// DOM node — unlike outerHTML replacement, which swaps the element for a new
// node and leaves any cached reference pointing at a detached one.
const camFrameVisual = document.getElementById('cam-frame-visual');
const camFrameThermal = document.getElementById('cam-frame-thermal');

function statusBadgeMarkup(status){
  if(status === 'fault') return '<span class="badge high">FAULT</span>';
  if(status === 'warning') return '<span class="badge med">WARNING</span>';
  return '<span class="badge low">NORMAL</span>';
}

// Shared grid geometry so the visual and thermal captures line up cell-for-cell.
const CAM_W = 400, CAM_H = 180;
const CAM_PAD_X = 40, CAM_PAD_Y = 20;
const CAM_GRID_COLS = 6, CAM_GRID_ROWS = 4;
const CAM_CELL_W = (CAM_W - CAM_PAD_X*2) / CAM_GRID_COLS;
const CAM_CELL_H = (CAM_H - CAM_PAD_Y*2) / CAM_GRID_ROWS;

// Deterministic (seeded by panel id) crack path, so the same "physical" crack
// renders in the same spot on both the visual photo and the thermal capture.
function getCrackPoints(data){
  const padX = CAM_PAD_X, padY = CAM_PAD_Y, gw = CAM_CELL_W, gh = CAM_CELL_H, w = CAM_W, h = CAM_H;
  const map = {
    "top-left corner": [padX+5, padY+5, padX+gw*1.5, padY+gh*1.2],
    "top edge": [padX+gw*1.5, padY+3, padX+gw*4.5, padY+gh*0.8],
    "top-right corner": [w-padX-5, padY+5, w-padX-gw*1.5, padY+gh*1.2],
    "left edge": [padX+3, padY+gh*1.2, padX+gw*0.8, h-padY-gh*1.2],
    "center": [padX+gw*2.2, padY+gh*1.3, padX+gw*3.8, h-padY-gh*1.3],
    "right edge": [w-padX-3, padY+gh*1.2, w-padX-gw*0.8, h-padY-gh*1.2],
    "bottom-left corner": [padX+5, h-padY-5, padX+gw*1.5, h-padY-gh*1.2],
    "bottom edge": [padX+gw*1.5, h-padY-3, padX+gw*4.5, h-padY-gh*0.8],
    "bottom-right corner": [w-padX-5, h-padY-5, w-padX-gw*1.5, h-padY-gh*1.2],
    "diagonal, corner to corner": [padX+5, padY+5, w-padX-5, h-padY-5]
  };
  const [x1,y1,x2,y2] = map[data.crackLocation] || map["center"];
  // Seed off the panel id so the jitter is stable across re-renders/images
  // instead of re-randomizing (and de-syncing) on every call.
  let seed = 0;
  for(const ch of data.id) seed += ch.charCodeAt(0);
  const midx = (x1+x2)/2 + ((seed % 21) - 10);
  const midy = (y1+y2)/2 + (((seed*7) % 21) - 10);
  return { x1, y1, midx, midy, x2, y2 };
}

function buildCameraThumbnail(data){
  // Generates a synthetic thermal capture for the selected panel
  const w = CAM_W, h = CAM_H, padX = CAM_PAD_X, padY = CAM_PAD_Y, gw = CAM_CELL_W, gh = CAM_CELL_H;
  const heatColor = data.status === 'fault' ? '#e4572e' : data.status === 'warning' ? '#f2c94c' : '#3ecf8e';

  let svgStr = `<svg width="100%" height="150" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg">`;
  svgStr += `<defs>
    <radialGradient id="camGrad" cx="50%" cy="60%" r="75%">
      <stop offset="0%" stop-color="${data.status==='fault' ? '#ffe28a' : data.status==='warning' ? '#fff3c2' : '#bdeedc'}" />
      <stop offset="35%" stop-color="${heatColor}" />
      <stop offset="75%" stop-color="#2a1a14" />
      <stop offset="100%" stop-color="#0a0f17" />
    </radialGradient>
  </defs>`;
  svgStr += `<rect width="${w}" height="${h}" fill="url(#camGrad)" />`;

  // panel cell grid overlay (simulate solar cell rows/cols on the physical panel)
  svgStr += `<g stroke="rgba(255,255,255,0.25)" stroke-width="1" fill="none">`;
  svgStr += `<rect x="${padX}" y="${padY}" width="${w-padX*2}" height="${h-padY*2}" stroke="rgba(255,255,255,0.4)" />`;
  for(let i=1;i<CAM_GRID_COLS;i++){
    const x = padX + i*gw;
    svgStr += `<line x1="${x}" y1="${padY}" x2="${x}" y2="${h-padY}" />`;
  }
  for(let i=1;i<CAM_GRID_ROWS;i++){
    const y = padY + i*gh;
    svgStr += `<line x1="${padX}" y1="${y}" x2="${w-padX}" y2="${y}" />`;
  }
  svgStr += `</g>`;

  // crack overlay
  if(data.cracked){
    const cp = getCrackPoints(data);
    svgStr += `<polyline points="${cp.x1},${cp.y1} ${cp.midx},${cp.midy} ${cp.x2},${cp.y2}" stroke="#0a0f17" stroke-width="2.5" fill="none" opacity="0.9" stroke-linecap="round" />`;
    svgStr += `<polyline points="${cp.x1},${cp.y1} ${cp.midx},${cp.midy} ${cp.x2},${cp.y2}" stroke="#ffffff" stroke-width="1" fill="none" opacity="0.7" stroke-linecap="round" />`;
  }

  // hotspot marker for fault panels
  if(data.status === 'fault'){
    svgStr += `<circle cx="${w*0.55}" cy="${h*0.55}" r="16" fill="none" stroke="#fff" stroke-width="2" opacity="0.85" />`;
    svgStr += `<text x="${w*0.55}" y="${h*0.55 - 22}" fill="#fff" font-size="12" font-family="monospace" text-anchor="middle">${data.temp}°C</text>`;
  }

  svgStr += `<text x="10" y="16" fill="rgba(255,255,255,0.6)" font-size="10" font-family="monospace">${data.id}</text>`;
  svgStr += `</svg>`;
  return svgStr;
}

function buildVisualThumbnail(data){
  // Generates a synthetic "real-life" RGB capture of the same panel — same
  // grid geometry and crack path as the thermal capture, so they read as two
  // views of the same physical panel rather than two unrelated images.
  const w = CAM_W, h = CAM_H, padX = CAM_PAD_X, padY = CAM_PAD_Y, gw = CAM_CELL_W, gh = CAM_CELL_H;

  let svgStr = `<svg width="100%" height="150" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg">`;
  svgStr += `<defs>
    <linearGradient id="panelGlass" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1c3a5e" />
      <stop offset="45%" stop-color="#0f2138" />
      <stop offset="100%" stop-color="#070f1a" />
    </linearGradient>
    <linearGradient id="sheen" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="rgba(255,255,255,0.22)" />
      <stop offset="100%" stop-color="rgba(255,255,255,0)" />
    </linearGradient>
  </defs>`;
  svgStr += `<rect width="${w}" height="${h}" fill="#05070b" />`;
  svgStr += `<rect x="${padX}" y="${padY}" width="${w-padX*2}" height="${h-padY*2}" fill="url(#panelGlass)" stroke="rgba(180,200,220,0.35)" />`;

  // silicon cell grid (silvery lines, like real cell busbars)
  svgStr += `<g stroke="rgba(150,180,210,0.35)" stroke-width="1">`;
  for(let i=1;i<CAM_GRID_COLS;i++){
    const x = padX + i*gw;
    svgStr += `<line x1="${x}" y1="${padY}" x2="${x}" y2="${h-padY}" />`;
  }
  for(let i=1;i<CAM_GRID_ROWS;i++){
    const y = padY + i*gh;
    svgStr += `<line x1="${padX}" y1="${y}" x2="${w-padX}" y2="${y}" />`;
  }
  svgStr += `</g>`;

  // soft sunlight sheen across the glass
  svgStr += `<polygon points="${padX},${padY} ${padX+(w-padX*2)*0.5},${padY} ${padX+(w-padX*2)*0.18},${h-padY} ${padX},${h-padY}" fill="url(#sheen)" opacity="0.55" />`;

  // dust/soiling film for warning-status panels
  if(data.status === 'warning' && !data.cracked){
    svgStr += `<rect x="${padX}" y="${padY}" width="${w-padX*2}" height="${(h-padY*2)*0.4}" fill="rgba(120,100,70,0.22)" />`;
  }

  // faint scorch discoloration echoing the thermal hotspot on fault panels
  if(data.status === 'fault'){
    svgStr += `<ellipse cx="${w*0.55}" cy="${h*0.55}" rx="26" ry="18" fill="rgba(40,25,15,0.45)" />`;
  }

  // crack overlay — identical geometry to the thermal capture
  if(data.cracked){
    const cp = getCrackPoints(data);
    svgStr += `<polyline points="${cp.x1},${cp.y1} ${cp.midx},${cp.midy} ${cp.x2},${cp.y2}" stroke="#04070b" stroke-width="2" fill="none" opacity="0.9" stroke-linecap="round" />`;
    svgStr += `<polyline points="${cp.x1},${cp.y1} ${cp.midx},${cp.midy} ${cp.x2},${cp.y2}" stroke="#dfe9f5" stroke-width="0.8" fill="none" opacity="0.55" stroke-linecap="round" />`;
  }

  svgStr += `<text x="10" y="16" fill="rgba(255,255,255,0.55)" font-size="10" font-family="monospace">${data.id}</text>`;
  svgStr += `</svg>`;
  return svgStr;
}

